{% liquid
  assign editorial_image = 'hero-organic-bedroom.jpg' | asset_url
  if section.settings.editorial_image != blank
    assign editorial_image = section.settings.editorial_image | image_url: width: 1500
  endif

  assign all_products_link = section.settings.all_products_link
  if all_products_link == blank
    assign all_products_link = routes.all_products_collection_url
  endif

  assign founding_sizes = section.settings.founding_sizes | downcase | split: ','
%}

<section class="nox-products-section nox-collection-showcase full-width" data-collection-showcase="{{ section.id }}">
  <div class="nox-collection-showcase__inner">
    <aside class="nox-collection-showcase__editorial">
      <img
        src="{{ editorial_image }}"
        alt="{{ section.settings.editorial_image.alt | default: section.settings.editorial_alt | escape }}"
        width="1120"
        height="1600"
        loading="lazy"
      >
      <div class="nox-collection-showcase__editorial-copy">
        <span>{{ section.settings.editorial_eyebrow }}</span>
        <strong>{{ section.settings.editorial_heading }}</strong>
      </div>
      <div class="nox-collection-showcase__benefits">
        <div><span aria-hidden="true">♧</span><p><strong>100%</strong> Organic Cotton</p></div>
        <div><span aria-hidden="true">≋</span><p><strong>Breathable</strong> &amp; Cooling</p></div>
        <div><span aria-hidden="true">◇</span><p><strong>Sustainably</strong> Made</p></div>
        <div><span aria-hidden="true">♢</span><p><strong>Gentle</strong> Sensitive Skin</p></div>
      </div>
    </aside>

    <div class="nox-collection-showcase__content">
      <header class="nox-collection-showcase__heading">
        <div>
          <p>
            {{ section.settings.eyebrow }}
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 3C10 4 4 9 4 16c0 3 2 5 5 5 7 0 10-7 11-18Z"/><path d="M5 22c4-7 8-11 13-15"/></svg>
          </p>
          <h2>{{ section.settings.heading }}</h2>
          <div class="nox-collection-showcase__description">{{ section.settings.description }}</div>
        </div>
        <a href="{{ all_products_link }}">
          {{ section.settings.all_products_label }}
          <span aria-hidden="true">→</span>
        </a>
      </header>

      {% if section.blocks.size > 0 %}
        <div class="nox-collection-tabs" role="tablist" aria-label="Product categories">
          {% for block in section.blocks %}
            {% assign category_collection = block.settings.collection %}
            <button
              type="button"
              role="tab"
              class="nox-collection-tab{% if forloop.first %} is-active{% endif %}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="NoxCollectionPanel-{{ block.id }}"
              data-collection-tab="{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              <svg viewBox="0 0 32 32" aria-hidden="true">
                {% case block.settings.icon %}
                  {% when 'pillow' %}
                    <path d="M5 9c0-2 2-4 4-4h14c2 0 4 2 4 4v14c0 2-2 4-4 4H9c-2 0-4-2-4-4V9Zm4 0h14v14H9z" />
                  {% when 'mattress' %}
                    <path d="M4 9h24v15H4zM7 9V6h18v3M4 19h24M8 13h7m2 0h7" />
                  {% when 'bundle' %}
                    <path d="M5 8h22v7H5zm-2 9h26v8H3zM8 5h16v3" />
                  {% else %}
                    <path d="M4 11h24v15H4zM7 11V7h18v4M4 20h24M8 14h7m2 0h7" />
                {% endcase %}
              </svg>
              <span>{{ block.settings.label | default: category_collection.title }}</span>
            </button>
          {% endfor %}
        </div>

        {% for block in section.blocks %}
          {% assign category_collection = block.settings.collection %}
          <div
            id="NoxCollectionPanel-{{ block.id }}"
            class="nox-collection-panel{% if forloop.first %} is-active{% endif %}"
            role="tabpanel"
            data-collection-panel="{{ block.id }}"
            {% unless forloop.first %}hidden{% endunless %}
          >
            <div class="nox-collection-panel__heading">
              <h3>{{ block.settings.panel_heading | default: category_collection.title }}</h3>
              {% if category_collection != blank %}
                <a href="{{ category_collection.url }}">
                  View all {{ block.settings.label | default: category_collection.title | downcase }}
                  <span aria-hidden="true">→</span>
                </a>
              {% endif %}
            </div>

            {% if category_collection != blank and category_collection.products.size > 0 %}
              <div class="nox-collection-products">
                {% for product in category_collection.products limit: section.settings.products_limit %}
                  {% assign founder_size = false %}
                  {% if section.settings.founding_product_tag == blank or product.tags contains section.settings.founding_product_tag %}
                    {% for variant in product.variants %}
                      {% assign variant_name = variant.title | downcase %}
                      {% for founding_size in founding_sizes %}
                        {% assign founding_size_name = founding_size | strip %}
                        {% if founding_size_name != blank and variant_name contains founding_size_name %}
                          {% assign founder_size = true %}
                          {% break %}
                        {% endif %}
                      {% endfor %}
                      {% if founder_size %}
                        {% break %}
                      {% endif %}
                    {% endfor %}
                  {% endif %}

                  <article class="nox-collection-product">
                    <a href="{{ product.url }}" class="nox-collection-product__link">
                      <div class="nox-collection-product__media">
                        {% if product.featured_image %}
                          {{ product.featured_image | image_url: width: 720 | image_tag: loading: 'lazy', alt: product.title }}
                        {% else %}
                          <img src="{{ 'category-bed-sheets.png' | asset_url }}" alt="{{ product.title | escape }}" width="720" height="720" loading="lazy">
                        {% endif %}
                        <span class="nox-collection-product__heart" aria-hidden="true">♡</span>
                        {% if founder_size %}
                          <span class="nox-collection-product__founder">King &amp; Twin pre-purchase</span>
                        {% endif %}
                      </div>
                      <div class="nox-collection-product__body">
                        <h4>{{ product.title | replace: 'TANDA', 'TANNA' }}</h4>
                        <p><span aria-hidden="true">★</span> Organic cotton comfort</p>
                        <div>
                          <strong>From {{ product.price_min | money }}</strong>
                          <span class="nox-collection-product__plus" aria-hidden="true">+</span>
                        </div>
                      </div>
                    </a>
                  </article>
                {% endfor %}
              </div>
            {% else %}
              <div class="nox-collection-panel__empty">
                <h4>Select a collection for this category.</h4>
                <p>Products from the chosen Shopify collection will appear here automatically.</p>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      {% else %}
        <div class="nox-collection-panel__empty">
          <h3>Add category blocks.</h3>
          <p>Add Bed Sheets, Pillow Cases, Mattress Covers, or Bundle collections in the theme editor.</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (() => {
    const showcase = document.querySelector('[data-collection-showcase="{{ section.id }}"]');
    if (!showcase) return;

    const tabs = showcase.querySelectorAll('[data-collection-tab]');
    const panels = showcase.querySelectorAll('[data-collection-panel]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.collectionTab;

        tabs.forEach((item) => {
          const active = item === tab;
          item.classList.toggle('is-active', active);
          item.setAttribute('aria-selected', active ? 'true' : 'false');
        });

        panels.forEach((panel) => {
          const active = panel.dataset.collectionPanel === target;
          panel.classList.toggle('is-active', active);
          panel.hidden = !active;
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Category Product Showcase",
  "max_blocks": 4,
  "settings": [
    {
      "type": "image_picker",
      "id": "editorial_image",
      "label": "Editorial image"
    },
    {
      "type": "text",
      "id": "editorial_alt",
      "label": "Editorial image alt text",
      "default": "Organic cotton bedding in a calm bedroom"
    },
    {
      "type": "text",
      "id": "editorial_eyebrow",
      "label": "Image eyebrow",
      "default": "GOTS Certified"
    },
    {
      "type": "text",
      "id": "editorial_heading",
      "label": "Image heading",
      "default": "Organic Cotton"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Everyday luxury, naturally"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Meet TANNA, your softer sleep ritual."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Thoughtfully made organic cotton bedding that feels soft, breathes naturally, and lasts beautifully."
    },
    {
      "type": "text",
      "id": "all_products_label",
      "label": "All-products link label",
      "default": "View all products"
    },
    {
      "type": "url",
      "id": "all_products_link",
      "label": "All-products link"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Products per category",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "founding_product_tag",
      "label": "Pre-purchase product tag",
      "default": "founding-prepurchase"
    },
    {
      "type": "text",
      "id": "founding_sizes",
      "label": "Pre-purchase size labels",
      "info": "Comma-separated variant names used for the premium pre-purchase badge.",
      "default": "Twin, King"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Product category",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Tab label",
          "default": "Bed Sheets"
        },
        {
          "type": "text",
          "id": "panel_heading",
          "label": "Product row heading",
          "default": "Best selling bed sheets"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "bed", "label": "Bed" },
            { "value": "pillow", "label": "Pillow" },
            { "value": "mattress", "label": "Mattress" },
            { "value": "bundle", "label": "Bundle" }
          ],
          "default": "bed"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Product Showcase",
      "blocks": [
        { "type": "category", "settings": { "label": "Bed Sheets", "panel_heading": "Best selling bed sheets", "icon": "bed" } },
        { "type": "category", "settings": { "label": "Complete Sets", "panel_heading": "Complete bedding sets", "icon": "bundle" } }
      ]
    }
  ]
}
{% endschema %}
