<section class="nox-collection-page full-width">
  {% render 'nox-breadcrumbs' %}

  <div class="nox-section-container">
    <div class="nox-section-heading">
      <p>Shop Nox Levia</p>
      <h1>{{ collection.title }}</h1>

      {% if collection.description != blank %}
        <div class="nox-collection-description">
          {{ collection.description }}
        </div>
      {% endif %}
    </div>

    <div class="nox-product-grid">
      {% for product in collection.products %}
        <a href="{{ product.url }}" class="nox-product-card">
          <div class="nox-product-image">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: product.title }}
            {% endif %}
          </div>

          <div class="nox-product-info">
            <h2>{{ product.title }}</h2>
            <p>{{ product.price | money }}</p>
          </div>
        </a>
      {% else %}
        <div class="nox-empty-products">
          <h2>No products found.</h2>
          <p>Add products to this collection in Shopify Admin.</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nox Main Collection",
  "settings": [],
  "presets": [
    {
      "name": "Nox Main Collection"
    }
  ]
}
{% endschema %}