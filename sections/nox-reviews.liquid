<section class="nox-reviews-section full-width">
  <div class="nox-section-container">
    <div class="nox-section-heading nox-heading-row">
      <div>
        <p>Customer comfort</p>
        <h2>Loved for softer sleep.</h2>
      </div>
      <div class="nox-reviews-summary" aria-label="Reviews will appear here after review app connection">
        <span aria-hidden="true">★★★★★</span>
        <small>Connect Judge.me, Loox, or Yotpo to display verified reviews</small>
      </div>
    </div>

    <div class="nox-review-placeholder">
      <div class="nox-review-placeholder-copy">
        <span class="nox-demo-label">Preview component · No customer claims published</span>
        <h3>Your verified reviews will feel right at home here.</h3>
        <p>
          This section is intentionally ready for a Shopify review app. Customer name, verified status, rating,
          review text, and product purchased can flow into this layout without using invented testimonials.
        </p>
      </div>
      <div class="nox-review-fields" aria-hidden="true">
        <span>★★★★★</span>
        <strong>Verified customer name</strong>
        <p>Real review content from your connected review provider.</p>
        <small>Purchased: TANNA Organic Cotton Sheet Set</small>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews Placeholder",
  "settings": [],
  "presets": [{ "name": "Reviews Placeholder" }]
}
{% endschema %}
