{% liquid
  assign selected_blog = section.settings.blog
  assign blog_url = routes.root_url | append: 'blogs/news'
  if selected_blog != blank
    assign blog_url = selected_blog.url
  endif
%}

<section class="nox-compact-blogs full-width">
  <div class="nox-compact-blogs__inner">
    <header class="nox-compact-blogs__heading">
      <div>
        <p>{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      <a href="{{ blog_url }}">
        {{ section.settings.link_label }}
        <span aria-hidden="true">→</span>
      </a>
    </header>

    {% if selected_blog != blank and selected_blog.articles.size > 0 %}
      <div class="nox-compact-blogs__grid">
        {% for article in selected_blog.articles limit: 3 %}
          <article class="nox-compact-blog{% if forloop.first %} nox-compact-blog--lead{% endif %}">
            <a href="{{ article.url }}" class="nox-compact-blog__media" aria-label="Read {{ article.title | escape }}">
              {% if article.image %}
                {{
                  article.image
                  | image_url: width: 1100
                  | image_tag: loading: 'lazy', alt: article.image.alt | default: article.title
                }}
              {% else %}
                <img
                  src="{% if forloop.first %}{{ 'hero-organic-bedroom.jpg' | asset_url }}{% elsif forloop.index == 2 %}{{ 'category-bed-sheets.png' | asset_url }}{% else %}{{ 'category-bedding-sets.png' | asset_url }}{% endif %}"
                  alt="{{ article.title | escape }}"
                  width="900"
                  height="600"
                  loading="lazy"
                >
              {% endif %}
            </a>

            <div class="nox-compact-blog__content">
              <div class="nox-compact-blog__meta">
                <span>{{ article.published_at | date: "%b %d, %Y" }}</span>
                {% if article.tags.first != blank %}<span>{{ article.tags.first }}</span>{% endif %}
              </div>
              <h3><a href="{{ article.url }}">{{ article.title }}</a></h3>
              <p>{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
              <a href="{{ article.url }}" class="nox-compact-blog__read">Read article <span aria-hidden="true">→</span></a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="nox-compact-blogs__grid">
        {% for index in (1..3) %}
          {% liquid
            if index == 1
              assign fallback_title = section.settings.fallback_1_title
              assign fallback_text = section.settings.fallback_1_text
              assign fallback_label = section.settings.fallback_1_label
              assign fallback_image = 'hero-organic-bedroom.jpg' | asset_url
            elsif index == 2
              assign fallback_title = section.settings.fallback_2_title
              assign fallback_text = section.settings.fallback_2_text
              assign fallback_label = section.settings.fallback_2_label
              assign fallback_image = 'category-bed-sheets.png' | asset_url
            else
              assign fallback_title = section.settings.fallback_3_title
              assign fallback_text = section.settings.fallback_3_text
              assign fallback_label = section.settings.fallback_3_label
              assign fallback_image = 'category-bedding-sets.png' | asset_url
            endif
          %}
          <article class="nox-compact-blog{% if index == 1 %} nox-compact-blog--lead{% endif %}">
            <a href="{{ blog_url }}" class="nox-compact-blog__media">
              <img src="{{ fallback_image }}" alt="{{ fallback_title | escape }}" width="900" height="600" loading="lazy">
            </a>
            <div class="nox-compact-blog__content">
              <div class="nox-compact-blog__meta"><span>{{ fallback_label }}</span></div>
              <h3><a href="{{ blog_url }}">{{ fallback_title }}</a></h3>
              <p>{{ fallback_text }}</p>
              <a href="{{ blog_url }}" class="nox-compact-blog__read">Read article <span aria-hidden="true">→</span></a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Compact Blogs",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Nox Levia edit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Better materials. Calmer bedrooms."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "View all blogs"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "header",
      "content": "Fallback content"
    },
    {
      "type": "text",
      "id": "fallback_1_label",
      "label": "Article 1 label",
      "default": "Material guide"
    },
    {
      "type": "text",
      "id": "fallback_1_title",
      "label": "Article 1 title",
      "default": "Why organic cotton changes the way your bed feels"
    },
    {
      "type": "textarea",
      "id": "fallback_1_text",
      "label": "Article 1 summary",
      "default": "A practical look at breathability, softness, and the standards behind considered bedding."
    },
    {
      "type": "text",
      "id": "fallback_2_label",
      "label": "Article 2 label",
      "default": "Care"
    },
    {
      "type": "text",
      "id": "fallback_2_title",
      "label": "Article 2 title",
      "default": "The uncomplicated guide to washing organic sheets"
    },
    {
      "type": "textarea",
      "id": "fallback_2_text",
      "label": "Article 2 summary",
      "default": "Simple care choices that preserve the natural texture and strength of cotton."
    },
    {
      "type": "text",
      "id": "fallback_3_label",
      "label": "Article 3 label",
      "default": "Sleep notes"
    },
    {
      "type": "text",
      "id": "fallback_3_title",
      "label": "Article 3 title",
      "default": "Building a bedroom that feels naturally calmer"
    },
    {
      "type": "textarea",
      "id": "fallback_3_text",
      "label": "Article 3 summary",
      "default": "A restrained approach to colour, texture, and breathable layers for better rest."
    }
  ],
  "presets": [
    {
      "name": "Compact Blogs"
    }
  ]
}
{% endschema %}
