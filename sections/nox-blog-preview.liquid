<section class="nox-blog-section full-width">
  <div class="nox-section-container">
    {% assign selected_blog = section.settings.blog %}

    <div class="nox-section-heading nox-heading-row">
      <div>
        <p>{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
      </div>

      {% if selected_blog != blank %}
        <a href="{{ selected_blog.url }}" class="nox-text-link">{{ section.settings.link_label }}</a>
      {% else %}
        <a href="{{ routes.root_url }}blogs/news" class="nox-text-link">{{ section.settings.link_label }}</a>
      {% endif %}
    </div>

    <div class="nox-blog-grid">
      {% if selected_blog.articles.size > 0 %}
        {% for article in selected_blog.articles limit: 3 %}
          <a href="{{ article.url }}" class="nox-blog-card">
            <span>{{ article.published_at | date: "%B %d, %Y" }}</span>
            <h3>{{ article.title }}</h3>
            <p>{{ article.excerpt_or_content | strip_html | truncate: 130 }}</p>
          </a>
        {% endfor %}
      {% else %}
        <a href="{{ routes.root_url }}blogs/news" class="nox-blog-card">
          <span>{{ section.settings.fallback_1_label }}</span>
          <h3>{{ section.settings.fallback_1_title }}</h3>
          <p>{{ section.settings.fallback_1_text }}</p>
        </a>

        <a href="{{ routes.root_url }}blogs/news" class="nox-blog-card">
          <span>{{ section.settings.fallback_2_label }}</span>
          <h3>{{ section.settings.fallback_2_title }}</h3>
          <p>{{ section.settings.fallback_2_text }}</p>
        </a>

        <a href="{{ routes.root_url }}blogs/news" class="nox-blog-card">
          <span>{{ section.settings.fallback_3_label }}</span>
          <h3>{{ section.settings.fallback_3_title }}</h3>
          <p>{{ section.settings.fallback_3_text }}</p>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nox Blog Preview",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Sleep better, naturally"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Guides for organic bedding and calmer sleep."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "Read the blog"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "header",
      "content": "Fallback cards"
    },
    {
      "type": "text",
      "id": "fallback_1_label",
      "label": "Card 1 label",
      "default": "Care Guide"
    },
    {
      "type": "text",
      "id": "fallback_1_title",
      "label": "Card 1 title",
      "default": "How to wash organic cotton sheets properly"
    },
    {
      "type": "text",
      "id": "fallback_1_text",
      "label": "Card 1 text",
      "default": "Keep your sheets soft, breathable, and fresh for longer."
    },
    {
      "type": "text",
      "id": "fallback_2_label",
      "label": "Card 2 label",
      "default": "Canada Sleep"
    },
    {
      "type": "text",
      "id": "fallback_2_title",
      "label": "Card 2 title",
      "default": "Best sheets for Canadian homes and seasons"
    },
    {
      "type": "text",
      "id": "fallback_2_text",
      "label": "Card 2 text",
      "default": "Choose bedding that feels comfortable through changing weather."
    },
    {
      "type": "text",
      "id": "fallback_3_label",
      "label": "Card 3 label",
      "default": "Material Guide"
    },
    {
      "type": "text",
      "id": "fallback_3_title",
      "label": "Card 3 title",
      "default": "Organic cotton vs regular cotton bedding"
    },
    {
      "type": "text",
      "id": "fallback_3_text",
      "label": "Card 3 text",
      "default": "Understand the difference before buying your next sheet set."
    }
  ],
  "presets": [
    {
      "name": "Nox Blog Preview"
    }
  ]
}
{% endschema %}
