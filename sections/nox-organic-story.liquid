<section class="nox-organic-story full-width" id="why-organic-cotton">
  <div class="nox-section-container nox-story-grid">
    <div class="nox-story-copy">
      <p class="nox-kicker">Why organic cotton?</p>
      <h2>Comfort that feels good in every sense.</h2>
      <p class="nox-story-lead">
        Your sheets spend hours against your skin. We choose certified organic cotton for its naturally breathable
        feel, gentle touch, and beautifully lived-in softness.
      </p>
      <a href="{{ routes.root_url }}pages/why-organic-cotton" class="nox-button nox-button-dark">Discover the difference</a>
    </div>

    <div class="nox-story-points">
      <article>
        <span>01</span>
        <div>
          <h3>Cool, breathable comfort</h3>
          <p>Natural fibres encourage airflow so your bed feels fresh through changing seasons.</p>
        </div>
      </article>
      <article>
        <span>02</span>
        <div>
          <h3>Gentle by nature</h3>
          <p>Soft against sensitive skin and made without harsh chemical finishing treatments.</p>
        </div>
      </article>
      <article>
        <span>03</span>
        <div>
          <h3>Softer with every wash</h3>
          <p>Durable cotton fibres relax beautifully over time while keeping their natural strength.</p>
        </div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Organic Cotton Story",
  "settings": [],
  "presets": [{ "name": "Organic Cotton Story" }]
}
{% endschema %}
