<section class="nox-gots-section full-width">
  <div class="nox-section-container">
    <div class="nox-gots-intro">
      <div class="nox-gots-seal" aria-label="Global Organic Textile Standard certified">
        <img src="{{ 'gots-certified-logo.webp' | asset_url }}" alt="Global Organic Textile Standard certified" width="190" height="190" loading="lazy">
      </div>
      <div>
        <p class="nox-kicker">Certified comfort</p>
        <h2>Good for your sleep. Considered at every step.</h2>
        <p>
          Certified by the Global Organic Textile Standard, our organic cotton is made with care for your skin,
          your sleep, and the planet.
        </p>
      </div>
    </div>

    <div class="nox-gots-heading">
      <h3>Why GOTS Matters</h3>
      <a href="{{ routes.root_url }}pages/gots-certification" class="nox-text-link">Learn about our certification</a>
    </div>

    <div class="nox-gots-grid nox-gots-grid-five">
      <article>
        <span aria-hidden="true">01</span>
        <h4>Organic Integrity</h4>
        <p>Verified organic fibres and traceability from harvesting through responsible manufacturing.</p>
      </article>
      <article>
        <span aria-hidden="true">02</span>
        <h4>Safer Textile Processing</h4>
        <p>Strict limits on harmful inputs help create cleaner textiles for your home and skin.</p>
      </article>
      <article>
        <span aria-hidden="true">03</span>
        <h4>Breathable Fabric</h4>
        <p>Natural cotton airflow supports a cooler, calmer sleep environment through every season.</p>
      </article>
      <article>
        <span aria-hidden="true">04</span>
        <h4>Sensitive-Skin Safe</h4>
        <p>Thoughtful material standards create a gentler everyday surface for delicate and sensitive skin.</p>
      </article>
      <article>
        <span aria-hidden="true">05</span>
        <h4>Ethically Grown</h4>
        <p>Environmental and social criteria support more responsible production from field to finish.</p>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "GOTS Education",
  "settings": [],
  "presets": [{ "name": "GOTS Education" }]
}
{% endschema %}
